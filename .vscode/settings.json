{
    // Editor settings
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.formatOnPaste": false,
    "editor.formatOnType": false,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
    },
    
    // Python-specific settings
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        },
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    
    // Ruff extension settings
    "ruff.enable": true,
    "ruff.lint.enable": true,
    "ruff.format.enable": true,
    "ruff.showSyntaxErrors": true,
    "ruff.organizeImports": true,
    "ruff.fixAll": true,
    
    // Python extension settings
    "python.analysis.autoImportCompletions": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoSearchPaths": true,
    "python.linting.enabled": false,  // Disable other linters since we're using ruff
    "python.formatting.provider": "none",  // Use ruff instead of other formatters
    
    // File associations
    "files.associations": {
        "*.py": "python"
    },
    
    // General editor settings for better Python development
    "editor.rulers": [88],  // Show line length ruler at 88 characters
    "editor.wordWrap": "off",
    "editor.trimAutoWhitespace": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    
    // Git settings
    "git.autofetch": true,
    "git.confirmSync": false,
    
    // Explorer settings
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.py": "${capture}.pyc",
        "pyproject.toml": "uv.lock,requirements.txt"
    }
} 